rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && request.auth.token.email == 'vmersin2022@gmail.com'; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    function isValidGift(data) {
      let hasReq = data.keys().hasAll(['title', 'status', 'createdAt', 'updatedAt']);
      let titleOk = data.title is string && data.title.size() <= 200;
      let statusOk = data.status in ['available', 'reserved'];
      let urlOk = !('url' in data) || (data.url is string && data.url.size() <= 1000);
      let imageUrlOk = !('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 1000);
      let rUidOk = !('reservedByUid' in data) || (data.reservedByUid is string && data.reservedByUid.size() <= 128);
      let rNameOk = !('reservedByName' in data) || (data.reservedByName is string && data.reservedByName.size() <= 200);
      
      return hasReq && data.keys().size() <= 8 &&
             titleOk && statusOk && urlOk && imageUrlOk && rUidOk && rNameOk &&
             data.createdAt is timestamp && data.updatedAt is timestamp;
    }

    match /admins/{userId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /gifts/{giftId} {
      allow read: if true;

      allow create: if isAdmin() &&
                    isValidId(giftId) &&
                    isValidGift(incoming()) &&
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time;
      
      allow update: if isValidId(giftId) && isValidGift(incoming()) &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time && (
                      isAdmin() ||
                      (
                        // Action: Reserve
                        incoming().status == 'reserved' &&
                        existing().status == 'available' &&
                        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'reservedByUid', 'reservedByName', 'updatedAt'])
                      ) ||
                      (
                        // Action: Un-reserve
                        incoming().status == 'available' &&
                        existing().status == 'reserved' &&
                        (!('reservedByUid' in incoming()) || incoming().reservedByUid == '') &&
                        (!('reservedByName' in incoming()) || incoming().reservedByName == '') &&
                        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'reservedByUid', 'reservedByName', 'updatedAt'])
                      )
                    );

      allow delete: if isAdmin() && isValidId(giftId);
    }
  }
}
